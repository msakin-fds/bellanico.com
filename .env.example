# WordPress Site Configuration
WORDPRESS_URL=https://bellanico.com
WORDPRESS_PATH=/home/YOUR_SSH_USER/www/bellanico.com/public_html
WORDPRESS_ADMIN_EMAIL=your_admin_email@example.com

# WordPress REST API — generate at:
# https://bellanico.com/wp-admin/ -> Users -> Your Profile -> Application Passwords
WP_REST_USER=your_wp_admin_username
WP_REST_PASSWORD=your_application_password

# SiteGround SSH Configuration
# Find these in SiteGround -> Hosting -> SSH Keys & Access
SSH_HOST=ssh.bellanico.com
SSH_PORT=18765
SSH_USER=your_siteground_ssh_user
SSH_KEY_PATH=/c/Users/SAKIN/.ssh/bellanico_rsa

# Database Configuration (via SSH tunnel)
# Find in SiteGround -> Site Tools -> Site -> MySQL -> Databases
DB_HOST=127.0.0.1
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_PORT=3306

# Project Settings
PROJECT_ENV=development
LOG_LEVEL=info
DEBUG=false
