# Copy this to .env and fill in the values. .env is gitignored.

# --- WordPress REST API ---
SITE_URL=https://bellanico.com
WP_USER=fdsthinkerwp
WP_APP_PASSWORD=          # 24-char application password (with or without spaces)

# --- SiteGround SSH ---
SSH_HOST=                 # e.g. giowm1081.siteground.biz
SSH_USER=                 # e.g. u1376-xxxxxxxxxxxx
SSH_PORT=18765
SSH_KEY=$HOME/.ssh/bellanico_siteground
DOC_ROOT=~/public_html    # path on the REMOTE server to WP install
